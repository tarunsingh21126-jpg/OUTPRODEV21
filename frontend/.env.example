# ===========================
# Required: Google Analytics 4
# ===========================
# Get your Measurement ID from Google Analytics: https://analytics.google.com/
# Format: G-XXXXXXXXXX
REACT_APP_GA4_ID=G-XXXXXXXXXX

# ===========================
# Core API Configuration
# ===========================
REACT_APP_API_URL=http://localhost:5000/api/

# ===========================
# Optional: HubSpot CRM
# ===========================
# Get your Hub ID from HubSpot: https://www.hubspot.com/
# Leave empty if not using HubSpot
REACT_APP_HUBSPOT_ID=

# ===========================
# Optional: Tawk.to Live Chat
# ===========================
# Get Property ID and Widget ID from Tawk.to: https://www.tawk.to/
# Leave empty if not using Tawk.to
REACT_APP_TAWK_PROPERTY_ID=
REACT_APP_TAWK_WIDGET_ID=

# ===========================
# Optional: Mailchimp Newsletter
# ===========================
# Option 1: Direct API (requires CORS handling)
REACT_APP_MAILCHIMP_API_KEY=
REACT_APP_MAILCHIMP_LIST_ID=
REACT_APP_MAILCHIMP_SERVER=us1

# Option 2: Hosted Form URL (recommended, no CORS issues)
# Get this from Mailchimp: Audience → Signup forms → Hosted signup form
REACT_APP_MAILCHIMP_FORM_URL=

